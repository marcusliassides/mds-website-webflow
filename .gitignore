# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Dependencies (none expected, but in case of dev tooling)
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
.cache/

# Local env
.env
.env.local
*.local

# Webflow exports (large; pulled fresh from designer)
webflow-export/
*.webflow.zip

# CMS seed CSVs are intentionally tracked — global *.csv ignore would
# otherwise drop them. The negation re-includes them.
!cms-collections/*.csv

# Asset working files
*.fig
*.psd
*.ai
~$*
